# Supabase credentials — copy to .env.local and fill in your values
# Get from: https://supabase.com/dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase setup SQL ───────────────────────────────────────────────────────
# Run this in your Supabase SQL Editor (Dashboard -> SQL Editor):
#
# create table public.payment_orders (
#   id          uuid        default gen_random_uuid() primary key,
#   order_id    text        unique not null,
#   status      text        not null default 'pending',
#   created_at  timestamptz default now()
# );
#
# alter table public.payment_orders enable row level security;
#
# create policy "anon_all" on public.payment_orders
#   for all to anon using (true) with check (true);
#
# -- Enable realtime for this table:
# alter publication supabase_realtime add table public.payment_orders;
# ─────────────────────────────────────────────────────────────────────────────
